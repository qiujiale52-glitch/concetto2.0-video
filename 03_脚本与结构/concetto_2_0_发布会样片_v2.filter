[0:v]split=2[bgintro][bgend];[1:v]split=2[logointro][logoend];
[bgintro]trim=duration=5,setpts=PTS-STARTPTS,scale=1280:720:force_original_aspect_ratio=increase,crop=1280:720,eq=brightness=-0.58:saturation=1.45[ibg];
