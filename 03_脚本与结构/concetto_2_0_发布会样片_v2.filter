[frontbg]drawbox=x=103:y=49:w=1074:h=610:color=0xC8B7FF@0.17:t=fill[frontstage];
[frontstage][frontui]overlay=(W-w)/2:62,drawbox=x=54:y=530:w=570:h=120:color=0x090512@0.70:t=fill,drawbox=x=54:y=548:w=6:h=75:color=0xB99AFF@1:t=fill,drawtext=fontfile='03-正版授权字体库/免费商用字体/MiSans/MiSans-Bold.ttf':text='全新前策分析':fontcolor=white:fontsize=39:x=80:y=545,drawtext=fontfile='03-正版授权字体库/免费商用字体/MiSans/MiSans-Regular.ttf':text='让每一次设计，从判断开始':fontcolor=0xE4DAFF:fontsize=21:x=80:y=596,drawtext=fontfile='03-正版授权字体库/免费商用字体/Roboto/Roboto-Bold.ttf':text='01 / STRATEGY':fontcolor=0xB99AFF:fontsize=15:x=80:y=626[front];

