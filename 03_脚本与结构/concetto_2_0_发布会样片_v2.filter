[modelbg]drawbox=x=103:y=49:w=1074:h=610:color=0xC8B7FF@0.17:t=fill[modelstage];
[modelstage][modelui]overlay=(W-w)/2:62,drawbox=x=54:y=530:w=625:h=120:color=0x090512@0.70:t=fill,drawbox=x=54:y=548:w=6:h=75:color=0xB99AFF@1:t=fill,drawtext=fontfile='03-正版授权字体库/免费商用字体/MiSans/MiSans-Bold.ttf':text='空间推演，即时发生':fontcolor=white:fontsize=39:x=80:y=545,drawtext=fontfile='03-正版授权字体库/免费商用字体/MiSans/MiSans-Regular.ttf':text='让策略判断，直接进入空间表达':fontcolor=0xE4DAFF:fontsize=21:x=80:y=596,drawtext=fontfile='03-正版授权字体库/免费商用字体/Roboto/Roboto-Bold.ttf':text='02 / MODEL':fontcolor=0xB99AFF:fontsize=15:x=80:y=626[model];

