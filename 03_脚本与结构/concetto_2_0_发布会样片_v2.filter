[ibg][ilogo]overlay=(W-w)/2:(H-h)/2-40,drawbox=x=0:y=0:w=1280:h=720:color=0x0B0716@0.16:t=fill,drawtext=fontfile='03-正版授权字体库/免费商用字体/Roboto/Roboto-Medium.ttf':text='2.0':fontcolor=0xC7AAFF:fontsize=30:x=(w-text_w)/2:y=430,drawtext=fontfile='03-正版授权字体库/免费商用字体/MiSans/MiSans-Regular.ttf':text='重构设计的起点':fontcolor=0xF4F0FF:fontsize=24:x=(w-text_w)/2:y=475,drawtext=fontfile='03-正版授权字体库/免费商用字体/Roboto/Roboto-Medium.ttf':text='2026  /  PRODUCT RELEASE':fontcolor=0xBCA4FF:fontsize=14:x=(w-text_w)/2:y=650[intro];

[2:v]trim=start=0:end=10,setpts=PTS-STARTPTS,fps=30,split=2[frontblur][frontpanel];
